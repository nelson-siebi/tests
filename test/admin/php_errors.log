[14-Jan-2026 08:34:48 America/New_York] [2026-01-14 08:34:48] SQL pour getPendingTransactions | DATA: "\n            SELECT \n                pt.*,\n                p.nom as plan_nom,\n                p.roi_journalier,\n                p.duree_jours,\n                u.nom,\n                u.prenom,\n                u.email,\n                u.phone,\n                TIMESTAMPDIFF(MINUTE, NOW(), pt.expires_at) as minutes_remaining,\n                CASE \n                    WHEN pt.expires_at < NOW() THEN 'expired'\n                    ELSE 'active'\n                END as expiration_status\n            FROM pending_transactions pt\n            LEFT JOIN plans p ON pt.plan_id = p.id\n            LEFT JOIN users u ON pt.user_id = u.id\n            WHERE pt.status = 'pending'\n            ORDER BY pt.created_at DESC\n        "
